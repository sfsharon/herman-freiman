---
const nav = [
  { name: "Home",        url: "/" },
  { name: "Biography",   url: "/biography/" },
  { name: "Timeline",    url: "/timeline/" },
  { name: "Family Tree", url: "/family/" },
  { name: "Gallery",     url: "/gallery/" },
  { name: "Documents",   url: "/documents/" },
  { name: "History",     url: "/history/" },
  { name: "Pinkas",      url: "/pinkas/" },
  { name: "Research",    url: "/research/" },
  { name: "About",       url: "/about/" },
];

const path = Astro.url.pathname;
---

<header class="site-header">
  <!-- Identity zone: light background, signature at original colors -->
  <div class="header-identity">
    <a href="/" class="signature-link">
      <img
        class="signature-img"
        src="/photos/Herman_Fraiman_Signature_Modified.png"
        alt="Return to home — Herman Freiman's signature"
      />
    </a>
    <span class="site-dates">1910 · Boryslaw, Galicia · Tailor · Partisan Member</span>
  </div>
  <!-- Navigation bar: dark -->
  <div class="site-nav-bar">
    <nav class="site-nav" aria-label="Main navigation">
      {nav.map(item => (
        <a
          href={item.url}
          class:list={["nav-link", { active: item.url === "/" ? path === "/" : path.startsWith(item.url) }]}
        >
          {item.name}
        </a>
      ))}
    </nav>
  </div>
</header>
