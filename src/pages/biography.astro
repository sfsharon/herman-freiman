        <tr><td>Hebrew Name</td><td>צבי (Zvi)</td></tr>
        <tr><td>Birth Date</td><td>March 2, 1910 (Note: Some documents show 1905)</td></tr>
        <tr><td>Birthplace</td><td>Boryslaw (Boryslav), Galicia, Poland (now Ukraine)</td></tr>
        <tr><td>Religion</td><td>Jewish (Jude)</td></tr>
        <tr><td>Profession</td><td>Schneider (Tailor)</td></tr>
        <tr><td>Languages</td><td>Polish, Yiddish (Jewish), Russian, Sign Language</td></tr>
