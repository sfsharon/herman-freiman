---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    heading: "Herman (Zvi) Freiman — Portraits",
    photos: [
      { src: "/photos/personal_Zvi_Fraiman_With_Suite_Age_40_Approx.png", caption: "Herman (Zvi) Freiman — portrait, circa age 40. Likely taken in Kfar Ata in the 1950s." },
      { src: "/photos/personal_Fraiman_Pic_27A.png", caption: "Herman (Zvi) Freiman — formal portrait." },
      { src: "/photos/personal_Fraiman_Pic_27B.png", caption: "Herman (Zvi) Freiman — formal portrait." },
    ]
  },
  {
    heading: "Herman and Ester",
    photos: [
      { src: "/photos/personal_Ester_and_Zvi_Fraiman_Adults.jpg",   caption: "Ester and Zvi (Herman) Freiman." },
      { src: "/photos/personal_Ester_and_Zvi_Fraiman_Adults_2.png", caption: "Ester and Zvi (Herman) Freiman." },
      { src: "/photos/personal_Ester_and_Zvi_Fraiman_Smiling.jpg",  caption: "Ester and Zvi (Herman) Freiman." },
    ]
  },
  {
    heading: "Family Photographs",
    photos: [
      { src: "/photos/personal_Zvi_and_Ester_With_Baby.png",              caption: "Zvi and Ester Freiman with one of their sons." },
      { src: "/photos/personal_Fraiman_Family__Three_Small_Children.png",  caption: "The Freiman family — Zvi, Ester, and their three sons." },
      { src: "/photos/personal_Family_Photo_Fraiman_Side.jpg",             caption: "The Freiman family." },
      { src: "/photos/personal_Fraiman_Familiy_Photos.jpg",                caption: "Family photographs." },
    ]
  },
  {
    heading: "Herman's Signature",
    photos: [
      { src: "/photos/Herman_Fraiman_Signature.jpg",         caption: "Herman Freiman's handwritten signature — as it appears on the 1959 Power of Attorney document." },
      { src: "/photos/Herman_Fraiman_Signature_Modified.png", caption: "Herman Freiman's signature — enhanced for legibility." },
    ]
  },
];
---

<BaseLayout
  title="Gallery"
  description="Family photographs of Herman Zvi Freiman and the Freiman family, from their years in Israel."
>
  <div class="gallery-page">
    <h1 class="gallery-title">Family Gallery</h1>
    <p class="gallery-intro">Personal photographs from the Freiman family archive. All photographs were taken in Israel, likely during the 1950s and 1960s.</p>

    {sections.map(section => (
      <section class="gallery-section">
        <h2 class="gallery-section-heading">{section.heading}</h2>
        <div class="gallery-grid">
          {section.photos.map(p => (
            <figure class="gallery-figure">
              <img src={p.src} alt={p.caption} loading="lazy" />
              <figcaption>{p.caption}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .gallery-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
  }

  .gallery-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--color-charcoal);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.5rem;
  }

  .gallery-intro {
    font-size: 0.92rem;
    color: var(--color-mid-gray);
    margin-bottom: 2.5rem;
  }

  .gallery-section {
    margin-bottom: 2.5rem;
  }

  .gallery-section-heading {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-mid-gray);
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .gallery-figure img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 2px;
    filter: sepia(15%) contrast(98%);
    display: block;
  }

  .gallery-figure figcaption {
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-mid-gray);
    font-style: italic;
    line-height: 1.4;
  }
</style>
