---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Herman (Zvi) Freiman — Memorial Archive"
  description="Memorial archive documenting the life of Herman Zvi Freiman, from Boryslaw, Galicia — compiled from Arolsen Archives, Yad Vashem, and personal family photographs."


  <!-- ── Hero: portrait + dedication text ── -->
  <section class="hero">
    <div class="hero-portrait">
      <img
        src="/photos/personal_Zvi_Fraiman_With_Suite_Age_40_Approx_modified.png"
        alt="Herman Zvi Freiman, approximately age 40"
      />
    </div>
    <div class="hero-text">
      <div class="hero-name-row">
        <h1 class="hero-name">Herman Zvi Freiman</h1>
        <span class="hero-name-heb" dir="rtl" lang="he">הרמן צבי פריימן</span>
      </div>
      <p class="hero-dates">Born March 2, 1910 · Boryslaw, Galicia · Tailor · Partisan</p>
      <blockquote class="hero-quote">
        Herman Zvi Freiman was born in Boryslaw Poland in 1910.<br />
        Survived three years in German Work Camp working as a tailor<br />
        At the end of WWII, escaped to join the Partisans. <br />
        Lost his wife Brunya and their child to the Holocaust<br />
        Remaried, immigrated to Israel, and began a new life.
      </blockquote>
      <p class="hero-body">
        This web site documents what was found of his life — drawn from Arolsen Archives
        records, Yad Vashem testimony, personal photographs, and family memory.
        It is a work in progress, assembled by his descendants.
      </p>
    </div>
  </section>

  <!-- ── Photo section cards ── -->
  <div class="section-cards">

    <a href="/biography/" class="photo-card">
      <img
        src="/photos/personal_Fraiman_Familiy_Photos_1_Modified.png"
        alt="Story of the War"
      />
      <div class="photo-card-label">
        <span class="photo-card-title">Biography</span>
        <span class="photo-card-desc">Identity, family, and documentary sources</span>
      </div>
    </a>

    <a href="/gallery/" class="photo-card">
      <img
        src="/photos/personal_Fraiman_Family__Three_Small_Children_Modified.png"
        alt="Ester and Zvi Fraiman"
      />
      <div class="photo-card-label">
        <span class="photo-card-title">Gallery</span>
        <span class="photo-card-desc">Family photographs</span>
      </div>
    </a>

    <a href="/timeline/" class="photo-card">
      <img
        src="/photos/personal_Zvi_and_Ester_With_Baby_Modified.png"
        alt="Fraiman family photograph"
      />
      <div class="photo-card-label">
        <span class="photo-card-title">Timeline</span>
        <span class="photo-card-desc">Chronological record, 1910-1960s</span>
      </div>
    </a>

    <a href="/documents/" class="photo-card">
      <img
        src="/photos/Herman_Fraiman_Signature_Modified.png"
        alt="Herman Freiman signature document"
        style="object-position: center top;"
      />
      <div class="photo-card-label">
        <span class="photo-card-title">Documents</span>
        <span class="photo-card-desc">Arolsen Archives, ITS cards, Vollmacht</span>
      </div>
    </a>

    <a href="/history/" class="photo-card">
      <img
        src="/photos/galicia_history.png"
        alt="History pic"
        style="object-position: center top;"
      />      
      <div class="photo-card-label">
        <span class="photo-card-title">History</span>
        <span class="photo-card-desc">Boryslaw, the Ghetto, and the Jewish community of eastern Galicia</span>
      </div>
    </a>

    <a href="/family/" class="photo-card">
      <img
        src="/photos/Freiman_family_tree.drawio.png"
        alt="Fraiman family group photograph"
      />
      <div class="photo-card-label">
        <span class="photo-card-title">Family Tree</span>
        <span class="photo-card-desc">Known relatives and name variants</span>
      </div>
    </a>

  </div>

  <!-- ── Timeline strip ── -->
  <section class="timeline-strip">
    <p class="timeline-heading">Key Dates</p>
    <ul class="timeline-list">
      <li class="milestone">
        <span class="milestone-year">1910</span>
        <span class="milestone-text">Born in Boryslaw, Galicia, to Faivel Freiman and Schifra Rosen</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">1939–41</span>
        <span class="milestone-text">Soviet occupation of eastern Galicia following the Molotov–Ribbentrop Pact; daily life disrupted</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">1941–44</span>
        <span class="milestone-text">German occupation; Boryslaw Ghetto and forced labor camp (ZAL) established; deportations to Bełżec — Herman survives as a tailor kept for essential labor</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">Mar 1944</span>
        <span class="milestone-text">Escaped the ZAL before the April deportation transports to Płaszów and Auschwitz; fought with partisan fighters in the surrounding forests</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">Aug 1944</span>
        <span class="milestone-text">Soviet forces liberate Boryslaw; Herman among approximately 400 survivors from a Jewish community of 13,000</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">1945–46</span>
        <span class="milestone-text">Settles in Bielawa, Poland (Wolności 131); marries Ester in 1945</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">1946–48</span>
        <span class="milestone-text">Displaced Persons Camp, Ulm Boelcke Kaserne, Germany; registered September 1946</span>
      </li>
      <li class="milestone">
        <span class="milestone-year">Nov 1948</span>
        <span class="milestone-text">Emigrates to Israel on the ship <em>Negba</em></span>
      </li>
      <li class="milestone">
        <span class="milestone-year">1948 →</span>
        <span class="milestone-text">Settles in Kfar Ata (now Kiryat Ata), near Haifa; raises five children with Ester; pursues restitution from West Germany</span>
      </li>
    </ul>
  </section>

  <!-- ── About this archive ── -->
  <section class="about-archive">
    <h2>About This Archive</h2>
    <p>
      This memorial website was created by Herman's descendants to preserve and share
      what is known of his life. Primary sources include the Arolsen Archives (ITS),
      Yad Vashem records, personal documents, and photographs held by the family in Israel.
      The archive is ongoing — corrections and additional testimony are welcome.
    </p>
  </section>

</BaseLayout>
