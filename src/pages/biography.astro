<style>
  .bio-header {
    display: grid;
    grid-template-columns: 210px 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2rem;
  }
  @media (max-width: 620px) {
    .bio-header { grid-template-columns: 1fr; }
  }

  .bio-portrait img {
    width: 100%;
    border-radius: 2px;
    filter: sepia(12%) contrast(97%);
  }
  .bio-portrait figcaption {
    font-size: 0.78rem;
    color: var(--color-mid-gray);
    font-style: italic;
    margin-top: 0.5rem;
    line-height: 1.4;
  }

  .bio-section-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
  }

  /* Remove top margin from table immediately following bio-section-label */
  .bio-keyinfo table {
    margin-top: 0;
  }

  .bio-pull {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-charcoal);
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 2rem 0;
    line-height: 1.7;
  }
</style>
