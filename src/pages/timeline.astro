---
import BaseLayout from '../layouts/BaseLayout.astro';

const TD       = "/docs/arolsen-td-790495-dp-cards-registry.pdf";
const CERT     = "/docs/its-td-file-790495-certificate-vollmacht.pdf";
const PINKAS   = "/pinkas/#second-world-war";
const PINKAS_ZAL = "/pinkas/#zal-liquidation";
const PINKAS_LIB = "/pinkas/#liberation";
const REGISTRY = "/docs/arolsen-polish-registry-entry.pdf";

const periods = [
  {
    title: "Pre-War Period",
    years: "1910–1941",
    events: [
      { year: "1910",     desc: "Born in Boryslaw, Galicia (then Austria-Hungary/Poland)", source: "DP-2 Cards, Polish Registry", url: TD },
      { year: "Pre-1938", desc: "Last permanent residence: Boryslaw, Poland", source: "ITS Certificate of Residence No. 413381", url: CERT },
      { year: "Pre-1941", desc: "Married first wife; children born (names unknown)", source: "Family oral history", url: null },
      { year: "—",        desc: "Worked as tailor (Schneider)", source: "All documents — TD File, DP-2 Cards, Certificate", url: CERT },
    ],
    note: null,
  },
  {
    title: "War Period",
    years: "1941–1944",
    events: [
      { year: "1 Jul 1941",  desc: "German occupation of Boryslaw begins", source: "Yad Vashem Pinkas HaKehillot — Boryslaw entry", url: "/pinkas/#german-occupation" },
      { year: "Jul 1941",    desc: "Confined to Ghetto Boryslaw", source: "ITS TD File 790 495 — summary card: '7.41–3.44 Gh. u. ZAL Boryslaw'", url: CERT },
      { year: "1941–1944",   desc: "Forced labor in ZAL (Zwangsarbeitslager) Boryslaw — most workers served the Karpathen Öl A.G. oil concern; Herman, as a tailor (Schneider), served the German administration", source: "ITS TD File 790 495; Pinkas HaKehillot", url: CERT },
      { year: "Unknown",     desc: "First wife and children perished during the Aktionen and deportations to the Belzec extermination camp", source: "Family oral history", url: null },
    ],
    note: "The Boryslaw ZAL was a forced labor camp serving the local oil industry, established after the October 1942 Aktion. Herman's profession as a tailor (Schneider) — a craft kept alive by the Germans for making and repairing clothing — is believed to have been the factor that kept him in local forced labor rather than the deportation trains to the Belzec extermination camp. The Pinkas HaKehillot confirms: 'craftsmen and persons in professions essential to the German economy' were the category specifically spared from final deportation.",
  },
  {
    title: "Escape and Liberation",
    years: "1944",
    events: [
      { year: "Mar 1944",     desc: "Escaped from ZAL Boryslaw — approximately one month before German forces liquidated the camp and deported its remaining inhabitants", source: "ITS TD File 790 495 — end date '3.44' in summary card", url: CERT },
      { year: "13 Apr 1944",  desc: "German forces liquidate ZAL Boryslaw: ~600 remaining Jews transferred to Płaszów concentration camp. Those who had not escaped were subsequently sent to Mauthausen and Auschwitz.", source: "Yad Vashem Pinkas HaKehillot — Boryslaw entry", url: PINKAS_ZAL },
      { year: "Mar–Aug 1944", desc: "Fought with partisan resistance fighters in the forests surrounding Boryslaw", source: "Family oral history; Pinkas HaKehillot (forest resistance groups)", url: PINKAS_ZAL },
      { year: "7 Aug 1944",   desc: "Boryslaw liberated by Soviet forces; Herman among the approximately 400 survivors who emerged", source: "Yad Vashem Pinkas HaKehillot — Boryslaw entry", url: PINKAS_LIB },
    ],
    note: "The Pinkas HaKehillot records that 'among the groups that hid in the forests, too, there were Jews equipped with weapons, who used them against their pursuers.' Herman's escape in March 1944 — before the 13 April deportation transport — almost certainly saved his life. It is the difference between his story and those of the hundreds who were taken to Płaszów and from there to Auschwitz.",
  },
  {
    title: "Post-War Period",
    years: "1945–1948",
    events: [
      { year: "1945",        desc: "Married Ester (née unknown) in Poland", source: "1959 ITS Form (TD File 790 495)", url: CERT },
      { year: "1945–1946",   desc: "Resided at Bielawa, Wolności 131, Poland", source: "Polish Jewish Registry, Warsaw — January 1947", url: REGISTRY },
      { year: "4 Sep 1946",  desc: "Arrived at DP Camp 678, Ulm Boelcke Kaserne", source: "DP-2 Card (ITS ref. 124269705) and DP-3 Card (ITS ref. 106106920)", url: TD },
      { year: "20 Nov 1946", desc: "Registered again at Ulm DP Camp", source: "DP-2 Card (ITS ref. 124269706)", url: TD },
      { year: "1 Jul 1947",  desc: "Still at Ulm Boelcke Kaserne DP Camp", source: "DP Camp List, Ulm (ITS ref. 82035163)", url: TD },
      { year: "30 Sep 1948", desc: "Left Ulm DP Camp for Israel", source: "Palestine Emigration List Nr. 19 (ITS ref. 82035128)", url: TD },
    ],
    note: null,
  },
  {
    title: "Israel Period",
    years: "1948 onwards",
    events: [
      { year: "4 Nov 1948",  desc: "Emigrated to Israel on ship Negba with wife Ester", source: "ITS Certificate of Residence No. 413381; 1959 ITS Form", url: CERT },
      { year: "Post-1948",   desc: "Settled at Hugo Moller Street 28, Kfar Ata-Giwat Ata", source: "ITS Certificate No. 413381 and all subsequent ITS documents", url: CERT },
      { year: "20 Oct 1959", desc: "Signed Power of Attorney for Dr. Herbert Mannheim (restitution)", source: "Vollmacht document (TD File 790 495, outbound)", url: CERT },
      { year: "26 Feb 1960", desc: "ITS Certificate of Residence issued", source: "Certificate No. 413381 (TD File 790 495, outbound)", url: CERT },
    ],
    note: "The Negba was one of several ships used by the nascent State of Israel to transport displaced persons from European DP camps. The family settled in Kfar Ata (today Kiryat Ata), a town near Haifa.",
  },
];
---

<BaseLayout
  title="Timeline"
  description="Herman Freiman's documented journey from birth in Boryslaw through the Holocaust to emigration and life in Israel."
>
  <div class="tl-page">
    <div class="prose tl-intro">
      <h1>Chronological Timeline</h1>
      <p>A chronological reconstruction of Herman Freiman's life, compiled from Arolsen Archives, Yad Vashem, and family records. Gaps remain in the wartime period — see <a href="/research/">Research Notes</a> for known unknowns and next steps.</p>
    </div>

    {periods.map(period => (
      <section class="vt-period">
        <div class="vt-period-header">
          <span class="vt-period-title">{period.title}</span>
          <span class="vt-period-years">{period.years}</span>
        </div>
        <div class="vt-events">
          {period.events.map(event => (
            <div class="vt-event">
              <span class="vt-year">{event.year}</span>
              <div class="vt-body">
                <p class="vt-desc">{event.desc}</p>
                {event.url
                  ? <a class="vt-source" href={event.url} target="_blank" rel="noopener">{event.source}</a>
                  : <span class="vt-source">{event.source}</span>
                }
              </div>
            </div>
          ))}
        </div>
        {period.note && <p class="vt-note">{period.note}</p>}
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .tl-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
  }

  .tl-intro {
    margin-bottom: 2.5rem;
  }

  /* Period section */
  .vt-period {
    margin-bottom: 2.5rem;
  }

  .vt-period-header {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .vt-period-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--color-charcoal);
  }

  .vt-period-years {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.08em;
  }

  /* Events list */
  .vt-events {
    display: flex;
    flex-direction: column;
  }

  .vt-event {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #ede4d0;
  }

  .vt-year {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-align: right;
    padding-top: 0.1rem;
    padding-right: 0.5rem;
    border-right: 2px solid var(--color-border);
    line-height: 1.4;
  }

  .vt-body {
    padding-top: 0.05rem;
  }

  .vt-desc {
    font-size: 0.9rem;
    color: var(--color-charcoal);
    margin: 0 0 0.15rem;
    line-height: 1.5;
  }

  .vt-source {
    font-size: 0.7rem;
    color: var(--color-mid-gray);
    font-style: italic;
  }
  a.vt-source {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }
  a.vt-source:hover {
    text-decoration-color: var(--color-accent);
  }

  /* Narrative note after a period */
  .vt-note {
    font-size: 0.86rem;
    color: var(--color-mid-gray);
    background: var(--color-parchment);
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1rem;
    margin-top: 0.75rem;
    border-radius: 0 2px 2px 0;
    line-height: 1.65;
  }
</style>
